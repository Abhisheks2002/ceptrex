# =====================================================================
# CEPTREX — Environment Variables (template)
# Copy to `.env` for local dev. NEVER commit real values.
# Variables prefixed with VITE_ are exposed to the browser bundle.
# All others are server-only (Cloudflare Worker / Node).
# =====================================================================

# -------- Application --------
NODE_ENV=development
VITE_APP_NAME=Ceptrex
VITE_SITE_URL=http://localhost:5173

# -------- Lovable Cloud / Supabase (optional) --------
# Enable via Lovable → Cloud, or create a Supabase project manually.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # SECRET — server only, bypasses RLS

# -------- AI Providers (optional, for Ask Ceptra / audits) --------
LOVABLE_API_KEY=                    # SECRET — Lovable AI Gateway
OPENAI_API_KEY=                     # SECRET
ANTHROPIC_API_KEY=                  # SECRET

# -------- Email (optional, for lead notifications) --------
RESEND_API_KEY=                     # SECRET

# -------- Booking (optional) --------
# The site uses Cal.com's public inline embed (no key needed).
# Set only if you switch to the authenticated REST API.
CALCOM_API_KEY=                     # SECRET

# -------- Analytics & Monitoring (optional) --------
VITE_GA_MEASUREMENT_ID=
VITE_POSTHOG_KEY=
VITE_CLARITY_PROJECT_ID=
SENTRY_DSN=                         # SECRET (server) / public DSN ok in VITE_
